@model GLMS.Models.ServiceRequest

<h2>Create Request</h2>

<form asp-action="Create" method="post">

    <div asp-validation-summary="All"></div>

    <div>
        Contract:
        <select asp-for="ContractId">
            @foreach (var c in ViewBag.Contracts)
            {
                <option value="@c.ContractId">@c.ContractId</option>
            }
        </select>
    </div>

    <div>
        Description:
        <input asp-for="Description" />
    </div>

    <div>
        Cost USD:
        <input asp-for="CostUSD" />
    </div>

    <button type="submit">Create</button>

</form>