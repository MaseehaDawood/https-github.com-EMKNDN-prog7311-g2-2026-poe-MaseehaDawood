@model GLMS.Models.Client

<h2>Create Client</h2>

<form asp-action="Create" method="post">

    <div asp-validation-summary="All"></div>

    <div>
        Name: <input asp-for="Name" />
    </div>

    <div>
        Contact: <input asp-for="ContactDetails" />
    </div>

    <div>
        Region: <input asp-for="Region" />
    </div>

    <button type="submit">Save</button>

</form>